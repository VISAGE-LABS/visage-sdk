{
  "name": "visage-sdk",
  "version": "1.0.0",
  "description": "Zero-dependency TypeScript SDK for the Visage B2B API — verify AI likeness licenses, log usage events, and manage deals.",
  "author": "Visage Labs <support@visagelabs.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/visagelabs/visage-sdk"
  },
  "homepage": "https://visagelabs.net",
  "keywords": [
    "visage",
    "ai",
    "likeness",
    "licensing",
    "sdk",
    "b2b",
    "api"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "visage-sdk": "^1.0.0"
  }
}
